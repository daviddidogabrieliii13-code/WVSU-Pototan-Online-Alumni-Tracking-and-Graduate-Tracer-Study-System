# Flask
SECRET_KEY=change-me

# OTP behavior
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=45
OTP_LOCKOUT_SECONDS=300
OTP_REQUEST_RATE_LIMIT_MAX=3
OTP_REQUEST_RATE_LIMIT_WINDOW_SECONDS=60
OTP_VERIFY_RATE_LIMIT_MAX=8
OTP_VERIFY_RATE_LIMIT_WINDOW_SECONDS=300
SHOW_OTP_IN_UI=False

# JWT session token
JWT_SECRET_KEY=change-me-too
JWT_EXPIRY_DAYS=7
AUTH_TOKEN_COOKIE_NAME=wvsu_auth_token

# Optional bootstrap password for freshly auto-seeded portal accounts
# If omitted, the legacy bootstrap password is used and the account will be forced
# to change that password on first successful sign-in.
# DEFAULT_PORTAL_SEED_PASSWORD=change-this-bootstrap-password

# Gmail SMTP (use App Password, not your regular Gmail password)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your-gmail-address@gmail.com
MAIL_PASSWORD=your-16-character-app-password
# Optional alias for Gmail App Password if you prefer this env var name
# GMAIL_APP_PASSWORD=your-16-character-app-password
MAIL_FROM=your-gmail-address@gmail.com

# Email delivery behavior
EMAIL_MOCK_MODE=False
MAIL_SUPPRESS_SEND=False

# RSVP access roles (comma separated)
# Examples:
# RSVP_ALLOWED_ROLES=alumni
# RSVP_ALLOWED_ROLES=alumni,student
RSVP_ALLOWED_ROLES=alumni
